# Copy to /share/Container/zadosti/.env on the NAS (NOT committed; .env is
# gitignored). docker-compose.nas.yml reads these. Fill real values.

# Login-gate password for the public site. Pick something strong.
ADMIN_PASSWORD=change-me

# Flask session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Anthropic API key for the document scan (Claude Vision) feature.
ANTHROPIC_API_KEY=sk-ant-...

# dataovozidlech.cz API key for the ORV lookup (previously hardcoded;
# rotate when convenient — old value is still in git history).
DATAOVOZIDLECH_API_KEY=...
